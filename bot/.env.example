# Copy to .env and fill in. Never commit .env (it is gitignored).

# From @BotFather when you create the bot
BOT_TOKEN=123456:ABC-your-token-here

# Your numeric Telegram user id. Message the bot /id after it is running,
# or use @userinfobot to find it. Only this user can post.
AUTHORIZED_USER_ID=000000000

# Absolute path to your local clone of the site repo (the folder with index.html)
SITE_DIR=/Users/hans/whats-new-in-china

# Public URL of the site, used only for the confirmation link the bot replies with
SITE_BASE_URL=https://hansstam86.github.io/whats-new-in-china

# --- LinkedIn cross-posting (optional) ---
# Leave these blank to disable. Site posting works fine without them.
# From your LinkedIn Developer app (Auth tab):
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
# Must match a redirect URL listed in the app's Auth tab:
LINKEDIN_REDIRECT_URI=http://localhost:8000/callback
# API version header, YYYYMM. Bump toward the current month if you get a version error:
LINKEDIN_VERSION=202506
